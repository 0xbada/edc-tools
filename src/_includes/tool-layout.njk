---
layout: base.njk
---
{% set title = tool.name %}
{% set description = tool.description %}

{% block head %}
<link rel="stylesheet" href="/css/tool.css">
{% endblock %}

<div class="tool-header">
  <h1 class="tool-title">{{ tool.name }}</h1>
  <p class="tool-desc">{{ tool.description }}</p>
</div>

<div class="action-bar" id="action-bar">
  <!-- common.js will populate action buttons here -->
</div>

<div class="panels">
  <div class="panel">
    <span class="panel-label">Input</span>
    <textarea class="panel-textarea" id="input" placeholder="Paste your text here..." spellcheck="false"></textarea>
  </div>
  <div class="panel">
    <span class="panel-label">Output</span>
    {% if tool.customOutput %}
    <pre class="panel-output" id="output"></pre>
    {% else %}
    <textarea class="panel-textarea output" id="output" readonly placeholder="Result will appear here..." spellcheck="false"></textarea>
    {% endif %}
  </div>
</div>

<div class="common-bar">
  <button class="common-btn" id="btn-copy">Copy</button>
  <button class="common-btn" id="btn-clear">Clear</button>
  <button class="common-btn" id="btn-swap">Swap</button>
</div>

<div class="ad-slot">
  <ins class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-9785162449902428"
    data-ad-slot="9820724311"
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>

<div class="tool-info">
  {{ content | safe }}
</div>

<script type="module" src="/js/common.js" data-tool-script="/js/tools/{{ tool.script }}"></script>
