<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Developer Tools") }} — DevHackDebug Tools</title>
  <meta name="description" content="{{ description | default("Free online developer utility tools") }}">
  <meta property="og:title" content="{{ title | default("Developer Tools") }} — DevHackDebug Tools">
  <meta property="og:description" content="{{ description | default("Free online developer utility tools") }}">
  <meta property="og:type" content="website">
  <link rel="stylesheet" href="/css/global.css">
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9785162449902428" crossorigin="anonymous"></script>
  {% block head %}{% endblock %}
</head>
<body>
  <header class="header">
    <nav class="nav">
      <a href="/" class="nav-logo">DHD TOOLS</a>
      <div class="nav-links">
        {%- for cat in categories %}
        <a href="/{{ cat.slug }}/">{{ cat.name }}</a>
        {%- endfor %}
      </div>
    </nav>
    <div class="ua-bar" id="ua-bar" title="Click to copy">
      <span id="ua-text"></span>
    </div>
  </header>
  <script>
    (function() {
      var el = document.getElementById('ua-text');
      var bar = document.getElementById('ua-bar');
      el.textContent = navigator.userAgent;
      bar.addEventListener('click', function() {
        navigator.clipboard.writeText(navigator.userAgent);
        el.textContent = 'Copied!';
        setTimeout(function() { el.textContent = navigator.userAgent; }, 1500);
      });
    })();
  </script>
  <main class="main">
    {{ content | safe }}
  </main>
  <footer class="footer">
    <p>DevHackDebug Tools — All processing happens in your browser. No data is sent to any server.</p>
    <div class="footer-links">
      <a href="/about/">About</a>
      <a href="/privacy/">개인정보처리방침</a>
      <a href="https://github.com/0xbada/edc-tools">GitHub</a>
    </div>
  </footer>
</body>
</html>
