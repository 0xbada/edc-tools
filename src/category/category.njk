---
pagination:
  data: categories
  size: 1
  alias: cat
permalink: "/{{ cat.slug }}/"
layout: base.njk
---
{% set title = cat.name + " Tools" %}
{% set description = cat.description %}

<div class="category-group">
  <h2 class="category-title">{{ cat.name }}</h2>
  <p style="color: var(--text-dim); font-size: 13px; margin-bottom: 20px;">{{ cat.description }}</p>
  <div class="tool-grid">
    {% for tool in tools | toolsByCategory(cat.slug) %}
    <a href="/{{ tool.category }}/{{ tool.slug }}/" class="tool-card">
      <div class="tool-card-name">{{ tool.name }}</div>
      <div class="tool-card-desc">{{ tool.description }}</div>
    </a>
    {% endfor %}
  </div>
</div>
